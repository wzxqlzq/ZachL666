{
  "run": {
    "mode": "once",
    "timezone": "Asia/Shanghai"
  },
  "selector": {
    "provider": "rule_based",
    "csv_path": "data/candidates.csv",
    "universe_csv_path": "data/stock_universe.csv",
    "min_avg_amount_20": 500000000,
    "min_atr_ratio": 0.03,
    "max_atr_ratio": 0.07,
    "min_market_cap": 20000000000
  },
  "market_data": {
    "provider": "akshare",
    "daily_csv_path": "data/sample_daily.csv",
    "lookback_days": 220,
    "adjust": "qfq",
    "timeout": 30,
    "history_source": "auto"
  },
  "service": {
    "candidate_pool_path": "data/candidates.csv",
    "loop_sleep_seconds": 1,
    "weekly_selection": {
      "enabled": true,
      "weekday": 6,
      "time": "00:30",
      "root": "data/offline",
      "output_dir": "selection_results",
      "lookback_days": 14,
      "workers": 4,
      "limit": 0,
      "provider": "akshare",
      "fallback": "eastmoney",
      "akshare_timeout": 30,
      "akshare_history_source": "sina",
      "market_cap_provider": "eastmoney",
      "market_cap_fallback": "tencent",
      "market_cap_page_size": 100,
      "request_delay": 0.5,
      "max_retries": 2,
      "update_scope": "selection",
      "bar_worker_mode": "process",
      "bar_workers": 4,
      "bar_batch_size": 20,
      "bar_timeout_seconds": 15,
      "final_retry_provider": "eastmoney",
      "skip_up_to_date_bars": true,
      "skip_existing_market_cap": false,
      "skip_market_cap_refresh": false,
      "notify_selection": false
    },
    "intraday": {
      "enabled": true,
      "offline_root": "data/offline",
      "quote_provider": "akshare",
      "interval_seconds": 60,
      "sessions": ["09:30-11:30", "13:00-15:00"]
    }
  },
  "strategy": {
    "entry_window": 55,
    "exit_window": 20,
    "atr_window": 20,
    "account_equity": 1000000,
    "risk_per_trade": 0.01,
    "confirm_minutes": 0,
    "lot_size": 100,
    "stop_atr_multiple": 2.0
  },
  "email": {
    "smtp_host": "smtp.example.com",
    "smtp_port": 465,
    "username": "your_email@example.com",
    "password": "your_smtp_app_password",
    "sender": "your_email@example.com",
    "recipients": ["your_email@example.com"]
  },
  "paths": {
    "portfolio": "portfolio.json",
    "signal_db": "state/signals.json",
    "orders_dir": "orders",
    "log_file": "logs/alerts.log"
  }
}
